                                @Model.Item1.RefundRateByAddress.ToString("0.#")%
                            </span>
                            @Html.ActionLinkWithImage(Url.Content("~/Content/icons/info.gif"), "GetRefundRateByAddressDetail",
                                new { zip = Model.Item1.Address != null ? Model.Item1.Address.Zip : "", addressLine1 = Model.Item1.Address != null ? Model.Item1.Address.AddressLine1 : "", addressLine2 = Model.Item1.Address != null ? Model.Item1.Address.AddressLine2 : "" },
                                new {
                                    title = "View Address Refunded Orders",
                                    onclick = "GetRefundRateByAddressDetail(this); return false",
                                    style = "vertical-align: top; cursor:pointer;",
                                    data_address = Model.Item1.Address != null ? ((Model.Item1.Address.AddressLine1 ?? "") + " " + (Model.Item1.Address.AddressLine2 ?? "")).Trim() : ""
                                })
                        </span>
                    </div>
                </div>
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           ORDER NOTES
           ══════════════════════════════════════════════════════════ *@
        @{List<NoteEntity> orderNotes =
              Model.Item1.OrderNotes.Select<OrderNotes, NoteEntity>(n => new NoteEntity
              {
                  NoteId = n.NoteId,
                  EntityId = n.EntityId,
                  NoteDate = n.NoteDate,
                  Note = n.Note,
                  IsUserNote = n.IsUserNote,
                  UserId = n.UserId
              }).OrderByDescending(e => e.NoteDate).ToList();
            NotesModel orderNotesModel = new NotesModel(orderNotes);
        }
        <div class="od-card">
            <div class="od-notes-header">
                <span>Order Notes (@orderNotes.Count)</span>
                @Html.ActionLink("+ Add Note", "SaveOrderNote", null,
                    new {
                        onclick = String.Format("add_note(this, {0}, '{1}', 'order-notes-div', {2}); return false;",
                          Model.Item1.OrderId, Url.Action("OrderNotes", new { orderId = @Model.Item1.OrderId }), 5),
                        @class = "od-action-link",
                        style = "font-weight: 600;"
                    })
            </div>
            <div id="order-notes-div" class="od-notes-body">
                @Html.Partial("NotesPartialView", orderNotesModel)
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           REFUNDS LIST (conditional)
           ══════════════════════════════════════════════════════════ *@
        @{
            var refunds = Model.Item1.GetOrderRefunds();
            var actionableRefunds = refunds.Where(r => String.IsNullOrWhiteSpace(r.TransactionId) && (r.Status == RefundStatus.Pending || r.Status == RefundStatus.Failed)).ToList();
            var refundButtonsEnabled = string.Equals(WebConfigurationManager.AppSettings["RefundButtonsEnabled"], "true", StringComparison.OrdinalIgnoreCase);
            var refundAdminOnly = string.Equals(WebConfigurationManager.AppSettings["RefundButtonsAdminOnly"], "true", StringComparison.OrdinalIgnoreCase);
            var refundUser = UserCache.GetUserByLogin(User.Identity.Name);
            var canSeeRefundButtons = refundButtonsEnabled && (!refundAdminOnly || (refundUser != null && refundUser.IsAdministrator));
        }
        @if (actionableRefunds.Count > 0 && Model.Item1.MarketId == (byte)MarketNames.MBWBStore && canSeeRefundButtons)
        {
            var orderPaymentMethods = (Model.Item1.PaymentTransactions ?? new List<OrderPayment>())
                .Where(pt => pt.RefundId == null)
                .Select(pt => pt.PaymentMethod)
                .Distinct()
                .ToList();
            var gcMethods = new[] { "Gift Certificate", "GiftCertificate" };
            var stripeMethods = new[] { "Stripe", "Visa", "MasterCard", "American Express", "Discover", "ApplePay" };
            var paypalMethods = new[] { "PayPal" };
            var hasGC = orderPaymentMethods.Any(pm => gcMethods.Any(g => g.Equals(pm, StringComparison.InvariantCultureIgnoreCase)));
            var hasStripe = orderPaymentMethods.Any(pm => stripeMethods.Any(s => s.Equals(pm, StringComparison.InvariantCultureIgnoreCase)));
            var hasPayPal = orderPaymentMethods.Any(pm => paypalMethods.Any(p => p.Equals(pm, StringComparison.InvariantCultureIgnoreCase)));

            <div class="od-card">
                <table class="od-refund-table" id="refunds">
                    <caption><strong>Refunds List</strong> (@actionableRefunds.Count pending)</caption>
                    <tr>
                        <th>SKU</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Reason</th>
                        <th>Created</th>
                        <th>Created By</th>
                        <th>Action</th>
                    </tr>
                    @foreach (var r in actionableRefunds)
                    {
                        <tr>
                            <td>@r.SKU</td>
                            <td>@r.AmountWithCurrency</td>
                            <td>@r.Status</td>
                            <td>@if (r.ReasonId != null) { @ReasonCache.GetName(Convert.ToInt16(r.ReasonId)) }</td>
                            <td>@r.Created</td>
                            <td>@UserCache.GetName(r.CreatedByUserId)</td>
                            <td id="refundAction@(r.RefundId)" style="white-space: nowrap;">
                                @if (hasGC)
                                {
                                    <input type="button" class="od-btn-sm" value="GC Refund" title="Refund to Gift Certificate"
                                           onclick="ProcessRefundPayment(@r.RefundId, @r.SellerId, 'GiftCertificate', '@Url.Action("ProcessGiftCertRefund")');" />
                                }
                                @if (hasStripe)
                                {
                                    <input type="button" class="od-btn-sm" value="Stripe Refund" title="Refund via Stripe"
                                           onclick="ProcessRefundPayment(@r.RefundId, @r.SellerId, 'Stripe', '@Url.Action("ProcessStripeRefund")');" />
                                }
                                @if (hasPayPal)
                                {
                                    if (ppTransaction != null)
                                    {
                                        @Html.ActionLink("PayPal Refund", "RefundOrderWithPayPalDialog", new { refundId = r.RefundId, sellerId = r.SellerId },
                                            new {
                                                @class = "od-btn-sm",
                                                style = "display: inline-block; text-decoration: none;",
                                                onclick = String.Format("ShowRefundOrderWithPayPalDialog(this, '{0}', '{1}?refundId={2}', {2}, {3}); return false;",
                                                    "Refund With PayPal", Url.Action("RefundOrderWithPayPal"), r.RefundId, r.SellerId),
                                                id = String.Format("refundPPDialog{0}", r.RefundId)
                                            })
                                    }
                                    <input type="button" class="od-btn-sm" value="PayPal API Refund" title="Refund via PayPal API"
                                           onclick="ProcessRefundPayment(@r.RefundId, @r.SellerId, 'PayPal', '@Url.Action("ProcessPayPalApiRefund")');" />
                                }
                                @if (!hasGC && !hasStripe && !hasPayPal)
                                {
                                    @:No recognized payment method (@String.Join(", ", orderPaymentMethods))
                                }
                            </td>
                        </tr>
                    }
                </table>
            </div>
        }

        @* ══════════════════════════════════════════════════════════
           SHIPMENTS
           ══════════════════════════════════════════════════════════ *@
        <div id="shipment-notes"></div>
        <div id="item-details" style="width:0; height:0;"></div>
        <div style="margin-bottom: 70px;">
            @{int shipmentCount = Model.Item2.Count();
                int counter = 0;
                foreach (Shipment shipment in Model.Item2)
                {
                    string heldId = String.Format("{0}_isHeld", shipment.ShipmentId);
                    string checkAllId = String.Concat("checkAll", shipment.ShipmentId);
                    counter++;

                    <div class="od-card">
                        @* ── Shipment header ── *@
                        <div class="od-card-header">
                            <input id="@checkAllId" type="checkbox" class="checkAllShipments"
                                   title="@String.Format("Select All Items for shipment #{0}", shipment.ShipmentId)" />
                            <label for="@checkAllId" title="Select All" style="font-size: 12px; cursor: pointer;">Select All</label>
                            <span class="od-separator"></span>
                            <span>
                                Shipment #<strong>@shipment.ShipmentId</strong>
                                <img src="~/Content/icons/Document-Copy-icon.png" class="od-copy-icon" onclick="CopyItem('@shipment.ShipmentId.ToString()'); return false;" />
                            </span>
                            <span style="font-size: 11px; color: #666;">(@counter of @shipmentCount)</span>
                            <span class="od-badge">@Html.Partial("StatusPartial", new StatusModel(shipment.Status, 0))</span>
                            @if (shipment.MarketBookOrders.Count > 1)
                            {
                                int ordersCount = shipment.MarketBookOrders.Select(m => m.OrderId).Distinct().Count();
                                @Html.Raw(String.Format("<span style='font-size:12px;'>({0} items, <b {2}>{1}</b> orders)</span>", shipment.MarketBookOrders.Count,
                                    ordersCount, ordersCount > 1 ? "style=\"color:Red\"" : String.Empty));
                            }
                            <span class="od-separator"></span>
                            <span style="font-size: 12px;">From: <b>@(shipment.LocationGroupName ?? "Unknown")</b></span>
                            @Html.ActionLinkWithImage(Url.Content("~/Content/icons/doc-edit-icon.png"), "Edit", "CheckEditOrder",
                                new { orderId = Model.Item1.OrderId, shipmentId = shipment.ShipmentId },
                                new { onclick = "EditOrder(this); return false", id = "editShipmentLink", @class = "od-action-link" })
                            @Html.ActionLink("Notes", "ShipmentNotes", new { shipmentId = shipment.ShipmentId },
                                new { title = "View Shipment Notes", @class = "od-action-link", onclick = "get_shipment_notes(this, " + shipment.ShipmentId + "); return false" })
                            @Html.Hidden(String.Format("{0}_shipmentIsHeld", shipment.ShipmentId), !shipment.IsHeld, new { id = String.Format("{0}_newShipmentIsHeldStatus", shipment.ShipmentId) })
                            @{
                                tagsTitle = shipment.GetTags();
                                haveTags = !String.IsNullOrWhiteSpace(tagsTitle);
                            }
                            @Html.ActionLink("Tags", "TagsView", new { entityId = shipment.ShipmentId, tagType = TagType.Shipment },
                                new {
                                    title = haveTags ? tagsTitle : noTagsMsg,
                                    @class = "od-action-link" + (haveTags ? " tags" : ""),
                                    @style = haveTags ? "color:Red" : String.Empty,
                                    onclick = "get_tags(this,'Shipment Tags [# " + shipment.ShipmentId + "]'); return false",
                                    id = String.Format("TagsLink{0}{1}", DateTime.Now.Second, DateTime.Now.Millisecond)
                                })
                            @Html.ActionLink("Postage Log", "ViewPostageLog", new { shipmentId = shipment.ShipmentId, sellerId = shipment.SellerId },
                                new { @class = "od-action-link", onclick = "ViewPostageLog(this); return false" })
                            <span class="od-hold-group">
                                <input id="@heldId" type="checkbox" title="Hold" @(shipment.IsHeld ? "checked" : String.Empty)
                                       onclick="update_shipment_isheld(@Model.Item1.OrderId, @shipment.ShipmentId, '@Url.Action("OrderNotes")', this)" />
                                <label for="@heldId">Hold</label>
                                @Html.Image(Url.Content("~/Content/icons/loading.gif"), null, new { id = @String.Format("{0}-held-loading", shipment.ShipmentId), style = "display:none" })
                            </span>
                            @if (shipment.Status == (byte)IndabaWeb.CC.Biz.Enums.OrderStatus.Shipped && shipment.ShippedDays > 0)
                            {
                                <span style="font-size: 12px; margin-left: 8px;">
                                    Days Since Shipped: <strong>@shipment.ShippedDays</strong>
                                </span>
                            }
                        </div>

                        @* ── Shipment metadata ── *@
                        <div class="od-shipment-meta">
                            <div>
                                <div class="od-meta-item">
                                    <span class="od-meta-label">Ship Date</span>
                                    <span class="od-meta-value">@DateTimeUtils.GetDateFromNullableDT(shipment.PostageDate)</span>
                                </div>
                                <div class="od-meta-item">
                                    <span class="od-meta-label">BNA Date</span>
                                    <span class="od-meta-value">@DateTimeUtils.GetDateFromNullableDT(shipment.BNADate)</span>
                                </div>
                                <div class="od-meta-item">
                                    <span class="od-meta-label">Tracking Id</span>
                                    <span class="od-meta-value">
                                        @Html.Raw(shipment.GetTrackingUrl())
                                        <img src="~/Content/icons/Document-Copy-icon.png" class="od-copy-icon" onclick="CopyItem('@Html.Raw(shipment.GetTrackingId())'); return false;" />
                                    </span>
                                </div>
                                @if (shipment.TrackingEvents != null && shipment.TrackingEvents.Any())
                                {
                                    <div class="od-meta-item">
                                        <span class="od-meta-label">Tracking Status</span>
                                        <span class="od-meta-value">
                                            <a href="#" onclick="const div = document.getElementById('@("divTrackingEvents_" + shipment.ShipmentId)'); div.style.display = (div.style.display === 'none') ? 'block' : 'none'; return false;">@shipment.TrackingStatus</a>
                                            <div id="@("divTrackingEvents_" + shipment.ShipmentId)" style="display:none;">
                                                @Html.Partial("TrackingEvents", shipment.TrackingEvents)
                                            </div>
                                        </span>
                                    </div>
                                }
                                <div class="od-meta-item">
                                    <span class="od-meta-label">Carrier</span>
                                    <span class="od-meta-value">
                                        @Html.Raw(shipment.GetCarrier())
                                        <img src="~/Content/icons/Document-Copy-icon.png" class="od-copy-icon" onclick="CopyItem('@Html.Raw(shipment.GetTrackingLink())'); return false;" />
                                    </span>
                                </div>
                                <div class="od-meta-item">
                                    <span class="od-meta-label">Delivery Confirmation</span>
                                    <span class="od-meta-value">@shipment.DeliveryStatus</span>
                                </div>
                            </div>
                            <div>
                                <div class="od-meta-item">
                                    <span class="od-meta-label">Shipping Method</span>
                                    <span class="od-meta-value">@shipment.MarketBookOrders.First().ShippingMethod</span>
                                </div>
                                <div class="od-meta-item">
                                    <span class="od-meta-label">Shipping Group</span>
                                    <span class="od-meta-value">@shipment.ShippingGroup</span>
                                </div>
                            </div>
                        </div>

                        @* ── Shipment items table ── *@
                        @{
                            var items = shipment.MarketBookOrders.OrderBy(orderItem => orderItem.OrderId == Model.Item1.OrderId ? 1 : 0)
                                .ThenBy(orderItem => orderItem.Title);
                            bool alternateColor = false;
                        }
                        <div class="od-items-toggle expand" onclick="">
                            Shipment Items (@items.Count())
                        </div>
                        <div class="collapse" style="@(shipment.MarketBookOrders.Count > 5 ? "display: none;" : String.Empty)">
                            <table class="od-items-table">
                                <tr>
                                    <th style="width: 30px;">&nbsp;</th>
                                    <th>Tags</th>
                                    <th>SKU</th>
                                    <th>ISBN</th>
                                    <th>Title</th>
                                    <th style="text-align: right;">Price Paid</th>
                                    <th style="text-align: right;">Breakdown</th>
                                    <th>Status</th>
                                    <th>Order #</th>
                                    <th>Received</th>
                                    <th>From Supplier</th>
                                    <th>Cancelled</th>
                                    <th>Cancel Reason</th>
                                    <th>Replaced</th>
                                    <th style="width: 70px;">Actions</th>
                                </tr>
                                @foreach (MarketBookOrder item in items)
                                {
                                    string rowStyle = "v1";
                                    if (item.OrderId != Model.Item1.OrderId)
                                    {
                                        rowStyle = alternateColor ? "v3" : "v4";
                                    }
                                    else
                                    {
                                        if (alternateColor) { rowStyle = "v2"; }
                                    }
                                    alternateColor = !alternateColor;
                                    tagsTitle = item.GetTags();
                                    haveTags = !String.IsNullOrWhiteSpace(tagsTitle);
                                    <tr class="@rowStyle">
                                        <td>
                                            <input type="checkbox" class="shipCheckbox"
                                                   id="@String.Concat("shipCheckbox", item.MarketBookOrderId)"
                                                   name="@String.Concat("shipCheckbox", item.ShipmentId)" />
                                            <input type="hidden" name="shipmentItem" id="@String.Concat("shipmentItem", item.MarketBookOrderId)" value="" />
                                            @Html.Hidden(String.Concat("canUncancel", item.MarketBookOrderId), item.CanDoUnCancel())
                                            @Html.Hidden(String.Concat("canUnrefund", item.MarketBookOrderId), item.CanDoUnrefund())
                                        </td>
                                        <td style="white-space: nowrap;">
                                            @Html.ActionLink("Tags", "TagsView", new { entityId = item.MarketBookOrderId, tagType = TagType.OrderItem },
                                                new {
                                                    title = haveTags ? tagsTitle : noTagsMsg,
                                                    @class = "tags",
                                                    @style = haveTags ? "color:Red" : String.Empty,
                                                    onclick = "get_tags(this,'Order Item Tags [# " + item.SKU + "]'); return false",
                                                    id = String.Format("TagsLink{0}{1}", DateTime.Now.Second, DateTime.Now.Millisecond)
                                                })
                                        </td>
                                        <td style="white-space: nowrap;">
                                            <a href="@Url.Action("ShipmentItemDetails", "Orders", new { mboId = item.MarketBookOrderId })"
                                               title="View item details" onclick="get_shipment_item_details(this); return false">
                                                <img src="@Url.Content("~/Content/icons/info.gif")" alt="details" style="vertical-align: middle; padding: 0;" />@item.SKU
                                            </a>
                                            @if (item.EBookOrderItemId.HasValue)
                                            {
                                                <br />
                                                <a href="@Url.Action("FulfillmentHistory", "Orders", new { mboId = item.BackOrderItemId.HasValue ? 0 : item.MarketBookOrderId })"
                                                   title="View Fulfillment History" onclick="get_fulfillment_history(this); return false">
                                                    <img src="@Url.Content("~/Content/icons/EBook.png")" alt="eBook" style="vertical-align: middle; padding: 0;" /> Fulfillment
                                                </a>
                                            }
                                        </td>
                                        <td>@item.ISBN</td>
                                        <td><div title="@item.Title">@(item.Title.Length > 50 ? item.Title.Substring(0, 47) + "..." : item.Title)</div></td>
                                        @{var itemPayments = Model.Item1.Payments.Where(x => x.OrderItemId == item.MarketBookOrderId && x.TransactionGroupId != 3 && x.TransactionGroupId != 4);}
                                        <td class="od-item-total">@itemPayments.Where(x => x.RefundId == null && x.TransactionGroupId != (int)TransactionGroupEnum.MarketCommission).GroupBy(l => l.OrderItemId).Select(orderItem => orderItem.Sum(p => p.Type == 1 ? -p.Amount : p.Amount)).FirstOrDefault().ToString("C", SellerCache.GetCurrencyInfo(item.SellerId))</td>
                                        <td style="text-align: right; width: 130px;">
                                            <div id="@("itemBreakdownCollapsed_" + item.MarketBookOrderId)">
                                                <a href="#" onclick="ExpandItemBreakdown(@item.MarketBookOrderId)">Expand +</a>
                                            </div>
                                            <div id="@("itemBreakdownExpanded_" + item.MarketBookOrderId)" hidden class="od-breakdown-detail">
                                                <a href="#" onclick="CollapseItemBreakdown(@item.MarketBookOrderId)">Collapse -</a>
                                                <div class="od-breakdown-line"><span>Subtotal:</span><span>@itemPayments.Where(x => x.RefundId == null && x.TransactionGroupId == (int)TransactionGroupEnum.PaymentForProduct).GroupBy(l => l.OrderItemId).Select(orderItem => orderItem.Sum(p => p.Type == 1 ? -p.Amount : p.Amount)).FirstOrDefault().ToString("C", SellerCache.GetCurrencyInfo(item.SellerId))</span></div>
                                                <div class="od-breakdown-line"><span>Discount:</span><span>@itemPayments.Where(x => x.RefundId == null && PooledTransactionGroup.IsDiscountGroup(x.TransactionGroupId)).GroupBy(l => l.OrderItemId).Select(orderItem => orderItem.Sum(p => p.Type == 1 ? -p.Amount : p.Amount)).FirstOrDefault().ToString("C", SellerCache.GetCurrencyInfo(item.SellerId))</span></div>
                                                <div class="od-breakdown-line"><span>Shipping:</span><span>@itemPayments.Where(x => x.RefundId == null && x.TransactionGroupId == (int)TransactionGroupEnum.PaymentForShipping).GroupBy(l => l.OrderItemId).Select(orderItem => orderItem.Sum(p => p.Type == 1 ? -p.Amount : p.Amount)).FirstOrDefault().ToString("C", SellerCache.GetCurrencyInfo(item.SellerId))</span></div>
                                                <div class="od-breakdown-line"><span>Tax:</span><span>@itemPayments.Where(x => x.RefundId == null && PooledTransactionGroup.IsTaxGroup(x.TransactionGroupId)).GroupBy(l => l.OrderItemId).Select(orderItem => orderItem.Sum(p => p.Type == 1 ? -p.Amount : p.Amount)).FirstOrDefault().ToString("C", SellerCache.GetCurrencyInfo(item.SellerId))</span></div>
                                                <div class="od-breakdown-line" style="font-weight: 700; border-top: 1px solid #ccc; padding-top: 2px;"><span>Total:</span><span>@itemPayments.Where(x => x.RefundId == null && x.TransactionGroupId != (int)TransactionGroupEnum.MarketCommission).GroupBy(l => l.OrderItemId).Select(orderItem => orderItem.Sum(p => p.Type == 1 ? -p.Amount : p.Amount)).FirstOrDefault().ToString("C", SellerCache.GetCurrencyInfo(item.SellerId))</span></div>
                                            </div>
                                        </td>
                                        <td style="white-space: nowrap;">@Html.Partial("StatusPartial", new StatusModel(item.Status, 0))</td>
                                        <td style="white-space: nowrap;">@Html.ActionLink(item.OrderNumber, "OrderDetails", new { OrderId = item.OrderId }, new { target = "_blank" })</td>
                                        <td>@ReceivedStatusCache.GetName(item.ReceivedStatusId) @item.OnSaleDate</td>
                                        <td>@(item.ShippedFromSupplier.HasValue ? item.ShippedFromSupplier.Value.ToShortDateString() : string.Empty)</td>
                                        <td>@(item.CancelationDate.HasValue ? item.CancelationDate.Value.ToString() : string.Empty)</td>
                                        <td>@item.CancelationReason</td>
                                        <td>@item.GetLastReplaceDate()</td>
                                        <td>
                                            <ul class="sddm" style="margin: 0; padding: 0;">
                                                <li>
                                                    <a href="#"
                                                       onmouseover="mopen('@item.MarketBookOrderId')"
                                                       onmouseout="mclosetime()">
                                                        <img src="@Url.Content("~/Content/icons/actions.png")" alt="actions" style="vertical-align: middle; padding: 0;" /> Actions
                                                    </a>
                                                    <div id="@item.MarketBookOrderId"
                                                         onmouseover="mcancelclosetime()"
                                                         onmouseout="mclosetime()">
                                                        @if (item.EBookOrderItemId.HasValue)
                                                        {
                                                            <a href="@Url.Action("ResetIngram", "Orders", new { mboId = item.BackOrderItemId.HasValue ? 0 : item.MarketBookOrderId })"
                                                               title="Reset eBook Download Link" onclick="reset_Ingram(this); return false">Reset eBook Download Link</a>
                                                        }
                                                        else
                                                        {
                                                            @Html.ActionLink("Replace", "Replace", new { marketBookOrderId = item.MarketBookOrderId, orderId = Model.Item1.OrderId },
                                                                new { onclick = "return check_replacement(this, " + (item.BackOrderItemId.HasValue ? item.BackOrderItemId.Value : 0) + ");" })
                                                        }
                                                    </div>
                                                </li>
                                            </ul>
                                        </td>
                                    </tr>
                                }
                            </table>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @* ══════════════════════════════════════════════════════════
       BOTTOM ACTION BAR
       ══════════════════════════════════════════════════════════ *@
    <div class="od-bottom-bar">
        <input type="submit" class="button rounded-corners" name="actionName" title="Cancel Selected Items" value="Cancel" />
        <input type="submit" class="button rounded-corners" name="actionName" title="Un-cancel Selected Items" value="Un-Cancel" id="UnCancelButton"
               style="display: none;" />
        <input type="submit" class="button rounded-corners" name="actionName" title="Refund Selected Items" value="Refund" />
        <input type="submit" class="button rounded-corners" name="actionName" title="Un-refund Selected Items" value="Un-Refund" id="UnRefundButton"
               style="display: none;" />
        <input type="submit" class="button rounded-corners" name="actionName" title="Restock Selected Items" value="Restock" />
        <input type="submit" class="button rounded-corners" name="actionName" title="Return Selected Items" value="Return" />
        <span class="od-items-count">Items Selected: <span class="itemsSelected">0</span></span>
    </div>

    <script>
        function ExpandItemBreakdown(marketBookOrder) {
            $("#itemBreakdownExpanded_" + marketBookOrder).show();
            $("#itemBreakdownCollapsed_" + marketBookOrder).hide();
        }
        function CollapseItemBreakdown(marketBookOrder) {
            $("#itemBreakdownExpanded_" + marketBookOrder).hide();
            $("#itemBreakdownCollapsed_" + marketBookOrder).show();
        }
        function CopyItem(item) {
            item = item.replace(/<br\s*[\/]?>/gi, "\n");
            navigator.clipboard.writeText(item);
        }
    </script>
}
