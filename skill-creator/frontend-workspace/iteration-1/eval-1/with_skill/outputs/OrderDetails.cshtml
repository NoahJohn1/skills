@using System.Collections.Generic
@using System.Text
@using System.Linq
@using System.Linq.Expressions
@using System.Configuration
@using System.Web.Configuration
@using IndabaWeb.CC.Biz
@using IndabaWeb.CC.Biz.Cache
@using IndabaWeb.CC.Biz.Enums
@using IndabaWeb.CC.DataBase
@using IndabaWeb.CC.Extensions
@using IndabaWeb.CC.Models.Orders
@using IndabaMerchant.Data
@using IndabaWeb.CC.Models.Enums

@model Tuple<Order, IEnumerable<Shipment>>
@{
    ViewBag.Title = string.Format("Order Details [{0}]", Model.Item1.MarketOrderNumber);
}

<style type="text/css">
    body {
        margin-bottom: 60px !important;
    }

    /* ── Page-level overrides for improved spacing & readability ── */

    .od-page {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 12px;
    }

    /* ── Card wrapper ── */
    .od-card {
        background: #fff;
        border: 1px solid #c5d9ad;
        border-radius: 4px;
        margin-bottom: 14px;
        overflow: hidden;
    }

    .od-card-header {
        background: linear-gradient(to bottom, #e8f3da, #d6e8c3);
        border-bottom: 1px solid #b3cc8f;
        padding: 8px 14px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 6px 14px;
        font-size: 13px;
        line-height: 1.6;
    }

    .od-card-header strong {
        font-size: 14px;
    }

    .od-card-header .od-action-link {
        color: #2e4914;
        text-decoration: none;
        padding: 2px 6px;
        border-radius: 3px;
        font-size: 12px;
        white-space: nowrap;
        transition: background 0.15s;
    }

    .od-card-header .od-action-link:hover {
        background: rgba(46, 73, 20, 0.1);
        color: #1a2e0a;
    }

    .od-card-header .od-badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        border-radius: 3px;
        font-size: 11px;
        font-weight: 600;
        background: #f0f4e8;
        border: 1px solid #c5d9ad;
    }

    .od-card-header .od-hold-group {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .od-card-header .od-btn-sm {
        padding: 3px 10px;
        font-size: 11px;
        border: 1px solid #8faa6a;
        background: #f5f9ef;
        border-radius: 3px;
        cursor: pointer;
        color: #2e4914;
        transition: background 0.15s;
    }

    .od-card-header .od-btn-sm:hover {
        background: #e0edcf;
    }

    .od-card-header .od-btn-sm:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .od-copy-icon {
        cursor: pointer;
        height: 10px;
        width: 10px;
        opacity: 0.5;
        transition: opacity 0.15s;
        vertical-align: middle;
    }

    .od-copy-icon:hover {
        opacity: 1;
    }

    /* ── Two-column info grid ── */
    .od-info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
        padding: 0;
    }

    @@media (max-width: 900px) {
        .od-info-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ── Data rows inside cards ── */
    .od-card-body {
        padding: 10px 14px;
    }

    .od-data-row {
        display: flex;
        align-items: baseline;
        padding: 4px 0;
        border-bottom: 1px solid #f0f0f0;
        font-size: 13px;
        line-height: 1.5;
    }

    .od-data-row:last-child {
        border-bottom: none;
    }

    .od-data-label {
        flex: 0 0 130px;
        font-weight: 600;
        color: #3a5a1e;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .od-data-value {
        flex: 1;
        color: #333;
    }

    .od-data-value .button {
        font-size: 11px;
        padding: 2px 8px;
    }

    /* ── Shipping address block ── */
    .od-address-block {
        background: #f9fbf5;
        border: 1px solid #e0e8d4;
        border-radius: 3px;
        padding: 8px 12px;
        font-size: 13px;
        line-height: 1.6;
        color: #444;
    }

    /* ── Customer section with refund badges ── */
    .od-refund-badge {
        display: inline-block;
        padding: 1px 8px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 600;
    }

    /* ── Notes section ── */
    .od-notes-header {
        background: #BDDE96;
        padding: 6px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-weight: 600;
        font-size: 13px;
        color: #2e4914;
        border-top: 1px solid #a5c87c;
    }

    .od-notes-body {
        padding: 4px 14px 10px;
        max-height: 200px;
        overflow-y: auto;
    }

    /* ── Refunds table ── */
    .od-refund-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .od-refund-table caption {
        text-align: left;
        background-color: #daebca;
        padding: 6px 14px;
        color: #333;
        font-weight: 600;
        font-size: 13px;
    }

    .od-refund-table th {
        background: #f0f5e8;
        padding: 6px 10px;
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: #3a5a1e;
        border-bottom: 2px solid #b3cc8f;
    }

    .od-refund-table td {
        padding: 6px 10px;
        border-bottom: 1px solid #e8e8e8;
    }

    /* ── Shipment card specifics ── */
    .od-shipment-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 20px;
        padding: 10px 14px;
        font-size: 13px;
    }

    @@media (max-width: 700px) {
        .od-shipment-meta {
            grid-template-columns: 1fr;
        }
    }

    .od-shipment-meta .od-meta-item {
        display: flex;
        padding: 3px 0;
        border-bottom: 1px solid #f5f5f5;
    }

    .od-shipment-meta .od-meta-label {
        flex: 0 0 160px;
        font-weight: 600;
        color: #555;
        font-size: 12px;
    }

    .od-shipment-meta .od-meta-value {
        flex: 1;
        color: #333;
    }

    /* ── Items table ── */
    .od-items-toggle {
        background: #f0f4e8;
        padding: 6px 14px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        color: #2e4914;
        border-top: 1px solid #d6e8c3;
        border-bottom: 1px solid #d6e8c3;
        user-select: none;
        transition: background 0.15s;
    }

    .od-items-toggle:hover {
        background: #e4ecd6;
    }

    .od-items-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 12px;
    }

    .od-items-table th {
        background: #f5f8ef;
        padding: 7px 8px;
        text-align: left;
        font-size: 11px;
        font-weight: 600;
        color: #3a5a1e;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        border-bottom: 2px solid #b3cc8f;
        white-space: nowrap;
    }

    .od-items-table td {
        padding: 6px 8px;
        vertical-align: top;
        border-bottom: 1px solid #eee;
    }

    .od-items-table tr.v1 { background-color: #fff; }
    .od-items-table tr.v2 { background-color: #f5f5f5; }
    .od-items-table tr.v3 { background-color: #FBBBB9; }
    .od-items-table tr.v4 { background-color: #F9966B; }

    .od-items-table tr:hover {
        background-color: #f0f5e6 !important;
    }

    .od-items-table tr.v3:hover,
    .od-items-table tr.v4:hover {
        opacity: 0.9;
    }

    .od-items-table a {
        color: #6633CC;
        text-decoration: none;
    }

    .od-items-table a:hover {
        text-decoration: underline;
        color: #FF3300;
    }

    .od-items-table a:visited {
        color: #006633;
    }

    .od-item-total {
        text-align: right;
        font-weight: 700;
        white-space: nowrap;
    }

    .od-breakdown-detail {
        font-size: 11px;
        line-height: 1.6;
        color: #555;
        text-align: right;
    }

    .od-breakdown-detail .od-breakdown-line {
        display: flex;
        justify-content: space-between;
        padding: 1px 0;
    }

    /* ── Bottom action bar ── */
    .od-bottom-bar {
        padding: 10px 20px;
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background: linear-gradient(to bottom, #e2f3d0, #cce8b5);
        border-top: 2px solid #83b44a;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        z-index: 100;
        box-shadow: 0 -2px 8px rgba(0,0,0,0.1);
    }

    .od-bottom-bar .button {
        padding: 6px 16px;
        font-size: 12px;
        font-weight: 600;
    }

    .od-bottom-bar .od-items-count {
        font-size: 13px;
        font-weight: 700;
        margin-left: 12px;
        color: #2e4914;
    }

    /* ── Utility ── */
    .od-separator {
        border-left: 1px solid #b3cc8f;
        height: 18px;
        display: inline-block;
        vertical-align: middle;
        margin: 0 4px;
    }
</style>

<script type="text/javascript">
    var inHistory = '@Model.Item1.IsInHistory',
        customerFullName = 'Customer Information [@Model.Item1.Customer.FullName]',
        addNoteLink = '@Html.ActionLink("Add Note", "SaveShipmentNote", null, new { id = "linkAddNote" })',
        orderNotesUrlWithId = '@Url.Action("OrderNotes", new { orderId = @Model.Item1.OrderId })',
        customerNotesUrl = '@Url.Action("CustomerNotes", new { customerId = @Model.Item1.CustomerId })',
        shipmentNotesUrl = '@Url.Action("ShipmentNotes")' + "?shipmentId=",
        holdShipmentUrl = '@Url.Action("HoldShipment")',
        searchOrderUrl = '@Url.Action("SearchOrder")?orderNumber=',
        orderDetailsUrl = '@Url.Action("OrderDetails")?orderId=',
        orderDetailsAbsoluteUrl = '@Url.Action("OrderDetails")',
        transactionDetailsUrl = '@Url.Action("TransactionDetails")',
        payPalIcon = '@Url.Content("~/Content/icons/pp.png")',
        OrderId = @Model.Item1.OrderId,
        processCheckedItemsUrl = '@Url.Action("ProcessCheckedItems")',
        SaveTagsUrl = '@Url.Action("SaveTags")',
        MarketOrderNumber = '@Model.Item1.MarketOrderNumber',
        LockedResourcesUrl = '@Url.Action("GetLockedResources")',
        EditOrderUrl = '@Url.Action("EditOrder")?orderId=@Model.Item1.OrderId.ToString()',
        CheckLockedUrl = '@Url.Action("CheckEditOrder")?orderId=@Model.Item1.OrderId.ToString()';
</script>

<script src="@Url.Content("~/Scripts/yui-min.js")" type="text/javascript"></script>
<script src="@Url.Content("~/Scripts/jquery.tooltip.js")" type="text/javascript"></script>
<script src="@Url.Content("~/Scripts/jquery.center.js")" type="text/javascript"></script>
<script src="@Url.Content("~/Scripts/cc.common.js")" type="text/javascript"></script>

@using (Html.BeginForm("OrderDetails", "Orders", new { orderId = Model.Item1.OrderId }))
{
    <input id="actionName" type="hidden" name="actionName" />
    @Html.Hidden("orderIds");
    @Html.Hidden("shipmentIds");
    @Html.Hidden("currentShipmentId")
    @Html.Hidden("unCancelbuttonVisible")
    @Html.Hidden("unRefundbuttonVisible")
    <input id="firstRun" type="hidden" />
    <script src="@Url.Content("~/Scripts/cc.order.notes.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/cc.order.details.js")" type="text/javascript"></script>
    <script src="@Url.Content("~/Scripts/cc.customer.details.js")" type="text/javascript"></script>
    <div id="add-notes" class="ModalWindow"></div>
    <div id="tags" class="ModalWindow"></div>
    <div id="payments" class="ModalWindow"></div>
    <div id="paypal_transaction" class="ModalWindow"></div>
    <div id="modal_window" class="ModalWindow"></div>

    <div class="od-page">

        @* ══════════════════════════════════════════════════════════
           ORDER HEADER CARD
           ══════════════════════════════════════════════════════════ *@
        <div class="od-card">
            <div class="od-card-header">
                <span>
                    Order #<strong>@Model.Item1.MarketOrderNumber</strong>
                    <img src="~/Content/icons/Document-Copy-icon.png" class="od-copy-icon"
                         onclick="CopyItem('@Html.Raw(Model.Item1.MarketOrderNumber.ToString())'); return false;" />
                </span>
                <span class="od-badge">@Html.Partial("StatusPartial", new StatusModel(Model.Item1.Status, 0))</span>
                @{
                    foreach (var sh in Model.Item2)
                    {
                        if (sh.MarketBookOrders.Where(mbo => mbo.GiftWrapping == true).Count() > 0
                            || sh.MarketBookOrders.Where(mbo => !String.IsNullOrWhiteSpace(mbo.GiftMessage)).Count() > 0)
                        {
                            <span>
                                @Html.ActionLinkWithImage(Url.Content("~/Content/icons/gift-icon.png"), "ShowGiftInformation",
                                    new { orderId = Model.Item1.OrderId },
                                    new { title = "Show gift information", onclick = "ShowGiftInformation(this)", @class = "od-action-link" })
                            </span>
                            break;
                        }
                    }
                }
                <span class="od-separator"></span>
                @Html.ActionLinkWithImage(Url.Content("~/Content/icons/doc-edit-icon.png"), "Edit", "CheckEditOrder", new { orderId = Model.Item1.OrderId },
                    new { onclick = "EditOrder(this); return false", id = "editOrderLink", @class = "od-action-link" })
                @{
                    string tagsTitle = Model.Item1.GetTags();
                    string noTagsMsg = "";
                    bool haveTags = !String.IsNullOrWhiteSpace(tagsTitle);
                }
                @Html.ActionLink("Tags", "TagsView", new { entityId = Model.Item1.OrderId, tagType = TagType.Order },
                    new {
                        title = haveTags ? tagsTitle : noTagsMsg,
                        @class = "od-action-link" + (haveTags ? " tags" : ""),
                        @style = haveTags ? "color:Red" : String.Empty,
                        onclick = "get_tags(this, 'Order Tags [# " + @Model.Item1.MarketOrderNumber + "]'); return false",
                        id = String.Format("TagsLink{0}{1}", DateTime.Now.Second, DateTime.Now.Millisecond)
                    })
                @Html.ActionLink("Payments", "PaymentsForOrder", new { orderId = Model.Item1.OrderId },
                    new { title = "View Payments", @class = "od-action-link", onclick = "get_payments(this, 'Order Payments [# " + @Model.Item1.MarketOrderNumber + "]'); return false" })
                @{var ppTransaction = Model.Item1.GetFirstPayPalTransaction();
                    if (ppTransaction != null)
                    {
                        <a href="@Url.Action("TransactionDetails", "Orders", new { paymentTransactionID = ppTransaction.TransactionID, showAll = true })"
                           class="od-action-link" title="View PayPal Transactions History"
                           onclick="get_paypal_transaction_details(this, '@("PayPal transactions for Order# [" + @Model.Item1.MarketOrderNumber + "]")', '@(ppTransaction.TransactionID)' ); return false">
                            <img src="@Url.Content("~/Content/icons/pp.png")" alt="PayPal" style="vertical-align: middle; height: 14px;" /> PayPal
                        </a>
                    }
                }
                @if (Model.Item1.MarketId == (byte)MarketNames.MBWBStore)
                {
                    var url = WebConfigurationManager.AppSettings["BWBAdminConsoleUrl"].ToString() + "\\Order\\Details\\?id=0&orderNumber=" + @Model.Item1.MarketOrderNumber;
                    <a href="@url" target="_blank" class="od-action-link">
                        <img src="@Url.Content("~/Content/icons/console-icon.png")" alt="Console" style="vertical-align: middle; height: 14px;" /> Admin Console
                    </a>
                }
                <span class="od-separator"></span>
                <span class="od-hold-group">
                    <input id="CheckboxHoldOrder" type="checkbox" title="Hold" @(Model.Item1.IsHeld ? "checked" : String.Empty)
                           onclick="update_order_isheld('@Url.Action("HoldOrder", new { OrderId = @Model.Item1.OrderId })', this)" />
                    <label for="CheckboxHoldOrder">Hold</label>
                    @Html.Image(Url.Content("~/Content/icons/loading.gif"), null, new { id = "order-held-loading", style = "display:none" })
                </span>
                @{
                    var block = Model.Item1.GetBlockOrderArrivalConfirmationButtonStatus();
                }
                <input title="@block.Item1" id="arrivalConfButton" type="button" class="od-btn-sm"
                       @(block.Item2 ? "disabled" : String.Empty)
                       onclick="BlockOrderArrivalConfirmation('@Url.Action("BlockOrderArrivalConfirmation")', this);"
                       value="@EnumTranslator.GetDescription(Model.Item1.ArrivalConfirmationEnum)" />
                <input class="od-btn-sm" id="orderStatusTemplateButton" type="button"
                       value="Status Template" onclick="GetOrderStatusTemplate('@Url.Action("GetOrderStatusTemplate")', this);" />
                @{
                    var signatures = Model.Item1.GetInHistoryText();
                }
                <input class="od-btn-sm" id="pendingOrHistoryButton" type="button"
                       title="@signatures.Item2" value="@signatures.Item1"
                       onclick="MoveToThePendingOrHistory('@Url.Action("MoveToThePendingOrHistory", new { orderId = Model.Item1.OrderId })', this)" />
                <input class="od-btn-sm" id="replacementsButton" type="button"
                       value="Multi-Replace" onclick="window.location.href ='@Url.Action("Index","MultiReplace", new {OrderId = Model.Item1.OrderId})';" />
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           ORDER INFO + CUSTOMER INFO — side by side
           ══════════════════════════════════════════════════════════ *@
        <div class="od-info-grid">
            @* ── Order Info ── *@
            <div class="od-card">
                <div class="od-card-header" style="padding: 6px 14px; font-size: 12px;">
                    <strong style="font-size: 13px;">Order Information</strong>
                </div>
                <div class="od-card-body">
                    <div class="od-data-row">
                        <span class="od-data-label">Market</span>
                        <span class="od-data-value" style="font-weight: 600; font-size: 14px;">@MarketCache.GetName(Model.Item1.MarketId.Value)</span>
                    </div>
                    <div class="od-data-row">
                        <span class="od-data-label">Seller</span>
                        <span class="od-data-value">
                            @SellerCache.GetName(Model.Item1.SellerId)
                            @{
                                var sellerLogin = SellerCache.GetSellerLoginUrl(Model.Item1.SellerId);
                                if (sellerLogin != String.Empty)
                                {
                                    <a href="@sellerLogin" target="_blank" style="color: #3388AA; margin-left: 6px; font-size: 12px;">Seller Login</a>
                                }
                            }
                        </span>
                    </div>
                    <div class="od-data-row">
                        <span class="od-data-label">Site Order Date</span>
                        <span class="od-data-value">@Model.Item1.DateOrdered.ToShortDateString()</span>
                    </div>
                    <div class="od-data-row">
                        <span class="od-data-label">Import Date</span>
                        <span class="od-data-value">@(Model.Item1.DateCreated != null ? Model.Item1.DateCreated.Value.ToShortDateString() : String.Empty)</span>
                    </div>
                </div>
                <div style="padding: 0 14px 10px;">
                    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 6px;">
                        <strong style="font-size: 12px; color: #3a5a1e; text-transform: uppercase; letter-spacing: 0.03em;">Shipping Address</strong>
                        <span>
                            <img src="~/Content/icons/Document-Copy-icon.png" class="od-copy-icon" onclick="CopyItem('@Html.Raw(Model.Item1.Address.ToString())'); return false;" />
                            @Html.Image(Url.Content("~/Content/icons/loading.gif"), null, new { id = "address-verification-loading", style = "display:none" })
                            <input id="AddresVerification" type="button" title="@EnumTranslator.GetDescription((VerificationStatus)Model.Item1.Address.VerificationStatus)"
                                   value="@EnumTranslator.GetDescription((VerificationStatus)Model.Item1.Address.VerificationStatus)"
                                   onclick="order_address_verification('@Url.Action("OrderShippingAddressVerification", new { orderId = @Model.Item1.OrderId })', this)"
                                   class="od-btn-sm" style="font-size: 10px;" />
                            @Html.ActionLink("History", "OrderShippingAddressChanges", new { orderId = Model.Item1.OrderId },
                                new {
                                    title = "Order Shipping Address Changes",
                                    @class = "od-action-link",
                                    style = "font-size: 11px;",
                                    onclick = "get_addres_changes(this, 'Order Shipping Address Changes for Order [# " + @Model.Item1.MarketOrderNumber + "]'); return false"
                                })
                        </span>
                    </div>
                    <div class="od-address-block">
                        @Html.Raw(Model.Item1.Address.ToString())
                    </div>
                    <div id="addres-changes"></div>
                </div>
            </div>

            @* ── Customer Info ── *@
            <div class="od-card">
                <div id="customer-info" style="width:0; height:0;"></div>
                <div class="od-card-header" style="padding: 6px 14px; font-size: 12px;">
                    <strong style="font-size: 13px;">Customer: @Model.Item1.Customer.FullName</strong>
                    @Html.ActionLink("Info / Notes", "Customer", new { customerId = Model.Item1.CustomerId, orderIdForBack = Model.Item1.OrderId },
                        new { title = "View Customer Info", @class = "od-action-link", onclick = "get_customer_info(this, customerFullName); return false" })
                    @{
                        tagsTitle = Model.Item1.GetCustomerTags();
                        haveTags = !String.IsNullOrWhiteSpace(tagsTitle);
                    }
                    @Html.ActionLink("Tags", "TagsView", new { entityId = Model.Item1.CustomerId, tagType = TagType.Customer },
                        new {
                            title = haveTags ? tagsTitle : noTagsMsg,
                            @class = "od-action-link" + (haveTags ? " tags" : ""),
                            @style = haveTags ? "color:Red" : String.Empty,
                            onclick = "get_tags(this,'Customer Tags<br/> [" + @Model.Item1.Customer.FullName + "]'); return false",
                            id = String.Format("TagsLink{0}{1}", DateTime.Now.Second, DateTime.Now.Millisecond)
                        })
                </div>
                @{
                    Func<decimal, string> refundRateColor = (rate) => {
                        var yellow = int.Parse(ConfigurationManager.AppSettings["RefundRateYellowThreshold"] ?? "15");
                        var red = int.Parse(ConfigurationManager.AppSettings["RefundRateRedThreshold"] ?? "20");
                        if (rate >= red) return "red";
                        if (rate >= yellow) return "#B2911C";
                        return "green";
                    };
                }
                <div class="od-card-body">
                    <div class="od-data-row">
                        <span class="od-data-label">Customer Id</span>
                        <span class="od-data-value">@Model.Item1.Customer.CustomerId</span>
                    </div>
                    <div class="od-data-row">
                        <span class="od-data-label">Email</span>
                        <span class="od-data-value">
                            @Model.Item1.Customer.Email
                            <img src="~/Content/icons/Document-Copy-icon.png" class="od-copy-icon" onclick="CopyItem('@Html.Raw(Model.Item1.Customer.Email.ToString())'); return false;" />
                            <input class="od-btn-sm" type="button" value="Send Email" style="margin-left: 6px;"
                                   onclick="window.location.href='@Url.Action("Compose", "Email", new { to = Model.Item1.Customer.Email, orderId = Model.Item1.OrderId, customerId = Model.Item1.CustomerId, customerName = Model.Item1.Customer.FullName, orderNumber = Model.Item1.MarketOrderNumber })';" />
                        </span>
                    </div>
                    <div class="od-data-row">
                        <span class="od-data-label">Phone</span>
                        <span class="od-data-value">@Model.Item1.Customer.Phone</span>
                    </div>
